{
  "name": "vienna-calling-todo-app",
  "version": "1.0.0",
  "private": true,
  "description": "A basic todo app to demonstrate interactive UI in React and FileMaker",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CodeoNordic/vienna-calling-web-components.git"
  },
  "author": "joaisa17",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/CodeoNordic/vienna-calling-web-components/issues"
  },
  "homepage": "https://github.com/CodeoNordic/vienna-calling-web-components#readme",
  "scripts": {
    "start": "parcel --no-cache --no-source-maps --no-hmr",
    "build": "parcel build --no-cache",
    "upload": "npm run build && node upload.js"
  },
  "source": "src/index.html",
  "publicUrl": "./",
  "targets": {
    "defaults": {
      "sourceMap": false,
      "scopeHoist": false,
      "context": "browser",
      "includeNodeModules": true
    }
  },
  "alias": {
    "react": "preact/compat",
    "react-dom": "preact/compat",
    "react-dom/client": "preact/compat/client",
    "react/jsx-runtime": "preact/jsx-runtime",
    "react/jsx-dev-runtime": "preact/jsx-runtime"
  },
  "engines": {
    "node": ">=20"
  },
  "browsersList": "> 0.5%, last 2 versions, not IE 9-11, not dead",
  "devDependencies": {
    "@parcel/optimizer-data-url": "^2.16.4",
    "@parcel/transformer-typescript-tsc": "^2.16.4",
    "@parcel/validator-typescript": "^2.16.4",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "cssnano": "^8.0.1",
    "htmlnano": "^3.3.1",
    "parcel": "^2.16.4",
    "postcss": "^8.5.15",
    "posthtml": "^0.16.7",
    "posthtml-doctype": "^1.1.1",
    "preact": "^10.29.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "open": "^11.0.0"
  }
}
