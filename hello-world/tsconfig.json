{
	"compilerOptions": {
		"allowJs": true,
		"allowSyntheticDefaultImports": true,
        "checkJs": true,
		"esModuleInterop": true,
		"experimentalDecorators": true,
		"jsx": "react-jsx",
		"module": "nodenext",
		"moduleResolution": "nodenext",
        "rootDir": ".",
		"paths": {
			"@icons/*": ["./src/icons/*"],
			"@/*": ["./src/*"]
		},
        "pretty": true,
        "removeComments": true,
		"sourceMap": false,
		"strict": true,
		"target": "esnext",
		"typeRoots" : ["./node_modules/@types", "./src/types"]
	},
	"include": [
		"./src/**/*.ts",
		"./src/**/*.tsx"
	],
	"exclude": [
		"node_modules/",
		"./src/**/**.deprecated.ts",
		"./src/**/**.deprecated.tsx"
	]
}